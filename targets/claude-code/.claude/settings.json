{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "agent": "sentinel-orchestrator",
  "env": {
    "CLAUDE_CODE_DISABLE_EXPLORE_PLAN_AGENTS": "1"
  },
  "permissions": {
    "deny": [
      "Agent(Explore)",
      "Agent(Plan)",
      "Agent(general-purpose)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./config/credentials.json)",
      "Read(./.aws/**)",
      "Read(./.ssh/**)"
    ]
  }
}
